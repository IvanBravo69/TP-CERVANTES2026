{
  "info": {
    "name": "Sistema Britos API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base", "value": "http://localhost:3000/api" },
    { "key": "token", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\"username\":\"admin\",\"password\":\"Admin1234!\"}"
            }
          }
        }
      ]
    },
    {
      "name": "Usuarios",
      "item": [
        {
          "name": "Listar",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base}}/usuarios?page=1&limit=10", "query": [
              { "key": "page", "value": "1" },
              { "key": "limit", "value": "10" }
            ]}
          }
        },
        {
          "name": "Crear",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base}}/usuarios",
            "body": {
              "mode": "raw",
              "raw": "{\"username\":\"mbritos\",\"password\":\"Segura#2024\",\"full_name\":\"María Britos\",\"email\":\"maria@sistemabitos.com\",\"role_id\":2}"
            }
          }
        },
        {
          "name": "Obtener por ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base}}/usuarios/1"
          }
        },
        {
          "name": "Editar",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base}}/usuarios/2",
            "body": {
              "mode": "raw",
              "raw": "{\"full_name\":\"Nombre Actualizado\",\"role_id\":3}"
            }
          }
        },
        {
          "name": "Desactivar",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base}}/usuarios/2/desactivar"
          }
        },
        {
          "name": "Activar",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base}}/usuarios/2/activar"
          }
        }
      ]
    },
    {
      "name": "Roles",
      "item": [
        {
          "name": "Listar",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base}}/roles"
          }
        },
        {
          "name": "Obtener con permisos",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base}}/roles/1"
          }
        }
      ]
    },
    {
      "name": "Permisos",
      "item": [
        {
          "name": "Listar",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base}}/permisos"
          }
        }
      ]
    }
  ]
}
